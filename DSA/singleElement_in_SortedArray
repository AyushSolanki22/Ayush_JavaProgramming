class Solution {
    public int singleNonDuplicate(int[] a) {
        //Full concept - 
       // 1.check kroo jo mid element hai vo pair mai hai ya kya 
       //2. Ye mid jo h ye phla hai ya dusra hai pair mai (occurence)
       //3. starting index(si) to dusri occurence tk agar even nos - to sab doubles mai , if odd -- left mai eek single element hai 
       //Or , pehle dusre occurence ke pair se left mai agar even nos . hai to no single there , or if odd, there is a single element
       //Vice versa for right 
       
       int mid=0,si=0,ei=a.length-1;
       
       while(si<=ei){
           mid=si+(ei-si)/2;
           
           if(mid>=1 && a[mid]==a[mid-1]){
               if((mid-1)%2==0){
                   //go right (as left all has doubles only)
                   si=mid+1;}
               else{
                 //go left(as left certainly has a single)
                 ei=mid-1;
               }
           }
           else if(mid<a.length-1   && a[mid]==a[mid+1]){
               if(mid%2==0){
                   //go right 
                   si=mid+1;
               }
               else ei=mid-1; //go left
           }
           else{
               return a[mid];
           }
       }
       return a[mid];
       
    }
}