
import java.util.*;
class Solution {
    public List<String> AllPossibleStrings(String s) {
    
        List<String> l=new ArrayList<>();
        subsets("",s,0,l); 
        Collections.sort(l);
        return l;
        
    } 
    static void subsets(String ans, String s, int idx, List<String> l){
        if(idx==s.length()){
            l.add(ans);
            return;
        }
        char ch=s.charAt(idx);
        subsets(ans+ch, s, idx+1,l); //pick
        subsets(ans, s, idx+1,l); //skip
    }
}